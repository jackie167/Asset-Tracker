{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm -C api-server build",
    "db:push": "pnpm -C lib/db exec drizzle-kit push --config ./drizzle.config.ts",
    "db:push:force": "pnpm -C lib/db exec drizzle-kit push --force --config ./drizzle.config.ts",
    "lint": "eslint api-server/src lib/db artifacts/finance-tracker/src",
    "start": "node index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
